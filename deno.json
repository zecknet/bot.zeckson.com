{
  "tasks": {
    "dev": "deno run --allow-read --allow-net --allow-env --watch --unstable-kv main.ts",
    "start": "deno run --allow-read --allow-net --allow-env server.ts",
    "predeploy": "deno run --allow-all --unstable-kv webhook.prod.ts",
    "predeploy:local": "deno run --allow-all --unstable-kv webhook.local.ts",
    "test": "deno test --allow-env --allow-sys",
    "lint": "deno lint"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1.0.19",
    "@std/testing": "jsr:@std/testing@1.0.19",
    "@std/dotenv": "jsr:@std/dotenv@0.225.6",
    "grammy": "npm:grammy@1.42.0",
    "replicate": "npm:replicate@1.4.0",
    "@grammyjs/parse-mode": "npm:@grammyjs/parse-mode@2.3.0",
    "@aws-sdk/client-ec2": "npm:@aws-sdk/client-ec2@3.588.0"
  },
  "vendor": true,
  "lock": {
    "frozen": true
  },
  "fmt": {
    "useTabs": true,
    "lineWidth": 80,
    "indentWidth": 4,
    "semiColons": false,
    "singleQuote": true,
    "proseWrap": "preserve",
    "include": ["src/", "server.ts", "main.ts"],
    "exclude": ["src/testdata/", "src/fixtures/**/*.ts"]
  },
  "deploy": {
    "org": "zeckson",
    "app": "zecknet"
  }
}
